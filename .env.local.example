# ─────────────────────────────────────────────────────────────────────────────
# Переменные окружения ki-school.
# Скопируйте этот файл в .env.local и подставьте значения из Supabase.
# (Supabase → Project Settings → API)
# ─────────────────────────────────────────────────────────────────────────────

# Публичные ключи (видны в браузере) – URL проекта и anon-ключ
NEXT_PUBLIC_SUPABASE_URL=https://ВАШ-ПРОЕКТ.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ваш-anon-public-ключ

# Секретный ключ (ТОЛЬКО на сервере, никогда не публиковать) –
# нужен для админ-операций (создание родителей, загрузка материалов).
SUPABASE_SERVICE_ROLE_KEY=ваш-service-role-секретный-ключ
